    "source_sql": "SELECT \n    stock_code,\n    stock_abbr,\n    report_period,\n    total_operating_revenue,\n    operating_revenue_yoy_growth,\n    operating_revenue_qoq_growth,\n    net_profit,\n    net_profit_yoy_growth,\n    net_profit_qoq_growth,\n    income_net_profit,\n    income_net_profit_yoy_growth,\n    (net_profit - income_net_profit) AS non_operating_income_estimate,\n    CASE \n        WHEN (net_profit - income_net_profit) > 0 \n        THEN '存在营业外收入或非经常性损益'\n        ELSE '无显著营业外收入'\n    END AS non_operating_income_status\nFROM financials_view \nWHERE stock_abbr = '凯莱英' \n    AND report_period IN ('2025Q3', '2025Q2', '2024Q3')\nORDER BY report_period DESC;",
