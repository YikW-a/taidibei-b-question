  "meta": {
    "source_sql": "WITH cash_data AS (\n    SELECT \n        stock_code,\n        stock_abbr,\n        report_period,\n        asset_cash_and_cash_equivalents AS balance_sheet_cash,\n        operating_cf_net_amount AS cash_flow_net_cash\n    FROM financials_view\n    WHERE report_period = '2025Q3'\n        AND (asset_cash_and_cash_equivalents IS NOT NULL \n             OR operating_cf_net_amount IS NOT NULL)\n)\nSELECT \n    stock_code,\n    stock_abbr,\n    report_period,\n    balance_sheet_cash,\n    cash_flow_net_cash,\n    (balance_sheet_cash - cash_flow_net_cash) AS difference\nFROM cash_data\nWHERE ABS(balance_sheet_cash - cash_flow_net_cash) > 0.01\n    OR (balance_sheet_cash IS NULL AND cash_flow_net_cash IS NOT NULL)\n    OR (balance_sheet_cash IS NOT NULL AND cash_flow_net_cash IS NULL)\nORDER BY ABS(difference) DESC, stock_abbr;",
    "value_fields": [
      "stock_code",
      "balance_sheet_cash",
      "cash_flow_net_cash",
      "difference"
    ],
