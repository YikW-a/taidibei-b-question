  "meta": {
    "source_sql": "WITH q3_2025 AS (\n    SELECT \n        stock_code,\n        stock_abbr,\n        net_profit AS net_profit_2025q3,\n        net_profit_yoy_growth AS reported_growth_2025q3\n    FROM financials_view\n    WHERE report_period = '2025Q3'\n),\nq3_2024 AS (\n    SELECT \n        stock_code,\n        stock_abbr,\n        net_profit AS net_profit_2024q3\n    FROM financials_view\n    WHERE report_period = '2024Q3'\n)\nSELECT \n    q25.stock_code,\n    q25.stock_abbr,\n    q25.net_profit_2025q3,\n    q24.net_profit_2024q3,\n    q25.reported_growth_2025q3 AS reported_yoy_growth,\n    CASE \n        WHEN q24.net_profit_2024q3 > 0 THEN q25.reported_growth_2025q3\n        WHEN q24.net_profit_2024q3 < 0 THEN \n            CASE \n                WHEN q25.net_profit_2025q3 > q24.net_profit_2024q3 THEN \n                    ((q25.net_profit_2025q3 - q24.net_profit_2024q3) / ABS(q24.net_profit_2024q3)) * 100\n                WHEN q25.net_profit_2025q3 < q24.net_profit_2024q3 THEN \n                    ((q25.net_profit_2025q3 - q24.net_profit_2024q3) / ABS(q24.net_profit_2024q3)) * 100\n                ELSE 0\n            END\n        ELSE NULL\n    END AS adjusted_growth\nFROM q3_2025 q25\nLEFT JOIN q3_2024 q24 ON q25.stock_code = q24.stock_code\nWHERE q25.reported_growth_2025q3 > 100.0\n    AND q24.net_profit_2024q3 IS NOT NULL\nORDER BY q25.reported_growth_2025q3 DESC;",
    "value_fields": [
      "stock_code",
      "net_profit_2025q3",
      "net_profit_2024q3",
      "reported_yoy_growth"
