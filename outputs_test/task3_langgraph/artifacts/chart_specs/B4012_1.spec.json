  "meta": {
    "source_sql": "SELECT * FROM (\nWITH current_q3 AS (\n    SELECT \n        stock_code,\n        stock_abbr,\n        report_period,\n        operating_expense_rnd_expenses AS rnd_expenses,\n        total_operating_revenue,\n        net_profit,\n        ROUND(CAST(operating_expense_rnd_expenses AS REAL) / NULLIF(total_operating_revenue, 0) * 100, 2) AS rnd_expense_ratio_percent\n    FROM financials_view\n    WHERE stock_abbr = '百诚医药' \n        AND report_period = '2025Q3'\n),\nprevious_q2 AS (\n    SELECT \n        stock_code,\n        stock_abbr,\n        report_period,\n        operating_expense_rnd_expenses AS rnd_expenses,\n        total_operating_revenue,\n        net_profit,\n        ROUND(CAST(operating_expense_rnd_expenses AS REAL) / NULLIF(total_operating_revenue, 0) * 100, 2) AS rnd_expense_ratio_percent\n    FROM financials_view\n    WHERE stock_abbr = '百诚医药' \n        AND report_period = '2025Q2'\n)\nSELECT \n    '2025Q3' AS period,\n    stock_abbr,\n    rnd_expenses,\n    total_operating_revenue,\n    rnd_expense_ratio_percent,\n    net_profit,\n    NULL AS rnd_expense_ratio_change,\n    NULL AS net_profit_change\nFROM current_q3\nUNION ALL\nSELECT \n    '2025Q2' AS period,\n    stock_abbr,\n    rnd_expenses,\n    total_operating_revenue,\n    rnd_expense_ratio_percent,\n    net_profit,\n    NULL AS rnd_expense_ratio_change,\n    NULL AS net_profit_change\nFROM previous_q2\nUNION ALL\nSELECT \n    '环比变化' AS period,\n    c.stock_abbr,\n    c.rnd_expenses - p.rnd_expenses AS rnd_expenses,\n    c.total_operating_revenue - p.total_operating_revenue AS total_operating_revenue,\n    c.rnd_expense_ratio_percent - p.rnd_expense_ratio_percent AS rnd_expense_ratio_percent,\n    c.net_profit - p.net_profit AS net_profit,\n    ROUND((c.rnd_expense_ratio_percent - p.rnd_expense_ratio_percent) / NULLIF(p.rnd_expense_ratio_percent, 0) * 100, 2) AS rnd_expense_ratio_change,\n    ROUND((c.net_profit - p.net_profit) / NULLIF(p.net_profit, 0) * 100, 2) AS net_profit_change\nFROM current_q3 c\nCROSS JOIN previous_q2 p\n) AS compound_result\nORDER BY \n    CASE period \n        WHEN '2025Q2' THEN 1 \n        WHEN '2025Q3' THEN 2 \n        WHEN '环比变化' THEN 3 \n    END;",
    "value_fields": [
      "rnd_expenses",
      "total_operating_revenue",
      "rnd_expense_ratio_percent",
      "net_profit"
    ],
