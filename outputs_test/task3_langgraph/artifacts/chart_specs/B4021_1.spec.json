  "meta": {
    "source_sql": "SELECT \n    stock_abbr,\n    report_period,\n    total_operating_revenue AS 营业总收入,\n    net_profit AS 净利润,\n    CASE \n        WHEN total_operating_revenue IS NOT NULL AND total_operating_revenue != 0 \n        THEN ROUND(net_profit * 100.0 / total_operating_revenue, 2)\n        ELSE NULL \n    END AS 净利润率\nFROM financials_view \nWHERE stock_abbr = '药明康德' \n    AND report_period IN ('2022Q3', '2023Q3', '2024Q3', '2025Q3')\nORDER BY report_period;",
