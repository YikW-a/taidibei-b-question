  "meta": {
    "source_sql": "SELECT * FROM (\nWITH current_q3 AS (\n    SELECT \n        stock_abbr,\n        report_period,\n        total_operating_revenue,\n        selling_expenses,\n        CASE \n            WHEN total_operating_revenue > 0 \n            THEN ROUND(selling_expenses * 100.0 / total_operating_revenue, 2)\n            ELSE NULL\n        END AS selling_expense_ratio\n    FROM financials_view\n    WHERE stock_abbr = '迪安诊断' \n        AND report_period = '2025Q3'\n),\nprev_q3 AS (\n    SELECT \n        stock_abbr,\n        report_period,\n        total_operating_revenue,\n        selling_expenses,\n        CASE \n            WHEN total_operating_revenue > 0 \n            THEN ROUND(selling_expenses * 100.0 / total_operating_revenue, 2)\n            ELSE NULL\n        END AS selling_expense_ratio\n    FROM financials_view\n    WHERE stock_abbr = '迪安诊断' \n        AND report_period = '2024Q3'\n)\nSELECT \n    '2025Q3' AS period,\n    c.total_operating_revenue AS current_revenue,\n    c.selling_expenses AS current_selling_expenses,\n    c.selling_expense_ratio AS current_selling_expense_ratio,\n    NULL AS prev_revenue,\n    NULL AS prev_selling_expenses,\n    NULL AS prev_selling_expense_ratio,\n    NULL AS revenue_growth_rate,\n    NULL AS selling_expense_ratio_change\nFROM current_q3 c\nUNION ALL\nSELECT \n    '2024Q3' AS period,\n    NULL,\n    NULL,\n    NULL,\n    p.total_operating_revenue,\n    p.selling_expenses,\n    p.selling_expense_ratio,\n    NULL,\n    NULL\nFROM prev_q3 p\nUNION ALL\nSELECT \n    '对比' AS period,\n    c.total_operating_revenue,\n    c.selling_expenses,\n    c.selling_expense_ratio,\n    p.total_operating_revenue,\n    p.selling_expenses,\n    p.selling_expense_ratio,\n    CASE \n        WHEN p.total_operating_revenue > 0 \n        THEN ROUND((c.total_operating_revenue - p.total_operating_revenue) * 100.0 / p.total_operating_revenue, 2)\n        ELSE NULL\n    END AS revenue_growth_rate,\n    ROUND(c.selling_expense_ratio - p.selling_expense_ratio, 2) AS selling_expense_ratio_change\nFROM current_q3 c\nCROSS JOIN prev_q3 p\n) AS compound_result\nORDER BY \n    CASE period \n        WHEN '2025Q3' THEN 1\n        WHEN '2024Q3' THEN 2\n        WHEN '对比' THEN 3\n        ELSE 4\n    END;",
    "value_fields": [
