  "meta": {
    "source_sql": "WITH derived_total_profit AS (\n    SELECT \n        stock_code,\n        stock_abbr,\n        report_period,\n        total_operating_revenue AS 营业收入,\n        operating_cost AS 营业成本,\n        selling_expenses AS 销售费用,\n        administrative_expenses AS 管理费用,\n        financial_expenses AS 财务费用,\n        taxes_and_surcharges AS 税金及附加,\n        total_profit AS 报表营业利润,\n        -- 公式推导：营业利润 = 营业收入 - 营业成本 - 销售费用 - 管理费用 - 财务费用 - 税金及附加\n        total_operating_revenue \n            - COALESCE(operating_cost, 0) \n            - COALESCE(selling_expenses, 0) \n            - COALESCE(administrative_expenses, 0) \n            - COALESCE(financial_expenses, 0) \n            - COALESCE(taxes_and_surcharges, 0) AS 推导营业利润,\n        -- 计算差异\n        total_profit - (total_operating_revenue \n            - COALESCE(operating_cost, 0) \n            - COALESCE(selling_expenses, 0) \n            - COALESCE(administrative_expenses, 0) \n            - COALESCE(financial_expenses, 0) \n            - COALESCE(taxes_and_surcharges, 0)) AS 差异金额,\n        -- 计算差异率（避免除零）\n        CASE \n            WHEN total_profit IS NOT NULL AND total_profit != 0 \n            THEN (total_profit - (total_operating_revenue \n                - COALESCE(operating_cost, 0) \n                - COALESCE(selling_expenses, 0) \n                - COALESCE(administrative_expenses, 0) \n                - COALESCE(financial_expenses, 0) \n                - COALESCE(taxes_and_surcharges, 0))) * 100.0 / ABS(total_profit)\n            ELSE NULL \n        END AS 差异率百分比\n    FROM financials_view\n    WHERE report_period IN ('2024FY', '2025Q1', '2025Q2', '2025Q3', '2025Q4', '2025H1')\n        AND total_operating_revenue IS NOT NULL\n        AND total_profit IS NOT NULL\n)\nSELECT \n    stock_code,\n    stock_abbr,\n    report_period,\n    营业收入,\n    营业成本,\n    销售费用,\n    管理费用,\n    财务费用,\n    税金及附加,\n    报表营业利润,\n    推导营业利润,\n    差异金额,\n    差异率百分比,\n    CASE \n        WHEN ABS(差异金额) < 0.01 THEN '匹配' \n        ELSE '不匹配' \n    END AS 匹配状态\nFROM derived_total_profit\nWHERE ABS(差异金额) >= 0.01  -- 只显示有差异的记录\nORDER BY ABS(差异金额) DESC, stock_abbr, report_period\nLIMIT 100;",
    "value_fields": [
      "stock_code",
      "营业收入",
      "营业成本",
      "销售费用"
    ],
