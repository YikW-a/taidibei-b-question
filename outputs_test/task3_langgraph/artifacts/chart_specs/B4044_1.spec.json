  "meta": {
    "source_sql": "WITH target_companies AS (\n  SELECT stock_code, stock_abbr\n  FROM financials_view\n  WHERE stock_abbr IN ('药明康德', '凯莱英', '百普赛斯')\n  GROUP BY stock_code, stock_abbr\n)\nSELECT \n  fv.stock_code,\n  fv.stock_abbr,\n  fv.report_period,\n  fv.total_operating_revenue AS 营业总收入,\n  fv.net_profit AS 净利润,\n  fv.net_profit_yoy_growth AS 净利润同比增长率,\n  fv.net_profit_qoq_growth AS 净利润环比增长率\nFROM financials_view fv\nJOIN target_companies tc ON fv.stock_code = tc.stock_code\nWHERE fv.report_period = '2025Q3'\nORDER BY fv.stock_abbr;",
    "value_fields": [
