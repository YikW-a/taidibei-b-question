  "meta": {
    "source_sql": "SELECT * FROM (\nWITH profit_components AS (\n    SELECT \n        stock_code,\n        stock_abbr,\n        report_period,\n        total_operating_revenue,\n        operating_cost,\n        selling_expenses,\n        administrative_expenses,\n        financial_expenses,\n        taxes_and_surcharges,\n        -- 计算营业利润 = 营业总收入 - 营业成本 - 期间费用 - 税金及附加\n        total_operating_revenue - operating_cost - selling_expenses - administrative_expenses - financial_expenses - taxes_and_surcharges AS operating_profit,\n        -- 计算利润总额（从利润表角度）\n        total_profit,\n        -- 计算投资收益 = 利润总额 - 营业利润（简化估算）\n        total_profit - (total_operating_revenue - operating_cost - selling_expenses - administrative_expenses - financial_expenses - taxes_and_surcharges) AS investment_profit_estimate,\n        net_profit,\n        net_profit_margin,\n        -- 投资收益占净利润比例\n        CASE \n            WHEN net_profit != 0 THEN \n                (total_profit - (total_operating_revenue - operating_cost - selling_expenses - administrative_expenses - financial_expenses - taxes_and_surcharges)) * 100.0 / net_profit \n            ELSE NULL \n        END AS investment_profit_to_net_profit_ratio\n    FROM financials_view\n    WHERE stock_abbr = '凯莱英' \n        AND report_period = '2025Q3'\n),\nhistorical_trend AS (\n    SELECT \n        stock_abbr,\n        report_period,\n        total_operating_revenue,\n        total_profit,\n        net_profit,\n        -- 计算历史投资收益估算\n        total_profit - (total_operating_revenue - operating_cost - selling_expenses - administrative_expenses - financial_expenses - taxes_and_surcharges) AS investment_profit_estimate,\n        -- 投资收益占净利润比例\n        CASE \n            WHEN net_profit != 0 THEN \n                (total_profit - (total_operating_revenue - operating_cost - selling_expenses - administrative_expenses - financial_expenses - taxes_and_surcharges)) * 100.0 / net_profit \n            ELSE NULL \n        END AS investment_profit_to_net_profit_ratio\n    FROM financials_view\n    WHERE stock_abbr = '凯莱英' \n        AND report_period IN ('2024Q3', '2025Q1', '2025Q2', '2025Q3')\n        AND total_operating_revenue IS NOT NULL\n        AND operating_cost IS NOT NULL\n        AND selling_expenses IS NOT NULL\n        AND administrative_expenses IS NOT NULL\n        AND financial_expenses IS NOT NULL\n        AND taxes_and_surcharges IS NOT NULL\n        AND total_profit IS NOT NULL\n)\nSELECT \n    '2025Q3详细分析' AS analysis_type,\n    stock_abbr,\n    report_period,\n    total_operating_revenue,\n    operating_cost,\n    selling_expenses,\n    administrative_expenses,\n    financial_expenses,\n    taxes_and_surcharges,\n    operating_profit,\n    total_profit,\n    investment_profit_estimate,\n    net_profit,\n    investment_profit_to_net_profit_ratio,\n    net_profit_margin\nFROM profit_components\nUNION ALL\nSELECT \n    '历史趋势对比' AS analysis_type,\n    stock_abbr,\n    report_period,\n    total_operating_revenue,\n    NULL AS operating_cost,\n    NULL AS selling_expenses,\n    NULL AS administrative_expenses,\n    NULL AS financial_expenses,\n    NULL AS taxes_and_surcharges,\n    NULL AS operating_profit,\n    total_profit,\n    investment_profit_estimate,\n    net_profit,\n    investment_profit_to_net_profit_ratio,\n    NULL AS net_profit_margin\nFROM historical_trend\n) AS compound_result\nORDER BY \n    CASE analysis_type \n        WHEN '2025Q3详细分析' THEN 1 \n        WHEN '历史趋势对比' THEN 2 \n        ELSE 3 \n    END,\n    CASE analysis_type \n        WHEN '历史趋势对比' THEN report_period \n        ELSE '2025Q3' \n    END;",
    "value_fields": [
