  },
  "sql": "WITH company_net_profit AS (\n    SELECT stock_code, stock_abbr, net_profit\n    FROM financials_view\n    WHERE report_period = '2025Q3'\n    AND net_profit IS NOT NULL\n    ORDER BY net_profit\n),\nmedian_calc AS (\n    SELECT net_profit AS median_net_profit\n    FROM (\n        SELECT net_profit,\n               ROW_NUMBER() OVER (ORDER BY net_profit) AS rn,\n               COUNT(*) OVER () AS total\n        FROM company_net_profit\n    )\n    WHERE rn IN ((total + 1) / 2, (total + 2) / 2)\n)\nSELECT cnp.stock_code, cnp.stock_abbr, cnp.net_profit, mc.median_net_profit\nFROM company_net_profit cnp\nCROSS JOIN median_calc mc\nWHERE cnp.net_profit > mc.median_net_profit\nORDER BY cnp.net_profit DESC;",
  "sql_history": [
    "WITH company_net_profit AS (\n    SELECT stock_code, stock_abbr, net_profit\n    FROM financials_view\n    WHERE report_period = '2025Q3'\n    AND net_profit IS NOT NULL\n    ORDER BY net_profit\n),\nmedian_calc AS (\n    SELECT net_profit AS median_net_profit\n    FROM (\n        SELECT net_profit,\n               ROW_NUMBER() OVER (ORDER BY net_profit) AS rn,\n               COUNT(*) OVER () AS total\n        FROM company_net_profit\n    )\n    WHERE rn IN ((total + 1) / 2, (total + 2) / 2)\n)\nSELECT cnp.stock_code, cnp.stock_abbr, cnp.net_profit, mc.median_net_profit\nFROM company_net_profit cnp\nCROSS JOIN median_calc mc\nWHERE cnp.net_profit > mc.median_net_profit\nORDER BY cnp.net_profit DESC;"
  ],
