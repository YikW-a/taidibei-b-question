  "meta": {
    "source_sql": "WITH ratio_data AS (\n  SELECT \n    stock_abbr,\n    asset_accounts_receivable,\n    total_operating_revenue,\n    CASE \n      WHEN total_operating_revenue > 0 THEN asset_accounts_receivable * 1.0 / total_operating_revenue\n      ELSE NULL\n    END AS accounts_receivable_ratio\n  FROM financials_view\n  WHERE report_period = '2025Q3'\n    AND total_operating_revenue IS NOT NULL\n    AND asset_accounts_receivable IS NOT NULL\n    AND total_operating_revenue > 0\n)\nSELECT \n  stock_abbr,\n  accounts_receivable_ratio\nFROM ratio_data\nWHERE accounts_receivable_ratio IS NOT NULL\nORDER BY accounts_receivable_ratio ASC\nLIMIT 3",
