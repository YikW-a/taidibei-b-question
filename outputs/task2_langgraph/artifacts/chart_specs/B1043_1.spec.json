  "meta": {
    "source_sql": "WITH ranked AS ( SELECT stock_code, stock_abbr, net_profit, gross_profit_margin, ROW_NUMBER() OVER (ORDER BY net_profit) AS rn, COUNT(*) OVER () AS cnt FROM financials_view WHERE report_period = '2025Q3'), median_rows AS ( SELECT AVG(net_profit) AS median_net_profit FROM ranked WHERE rn IN ((cnt + 1) / 2, (cnt + 2) / 2)), industry_avg AS ( SELECT AVG(gross_profit_margin) AS avg_gross_margin FROM ranked) SELECT r.stock_code, r.stock_abbr, r.net_profit, r.gross_profit_margin FROM ranked r CROSS JOIN median_rows m CROSS JOIN industry_avg a WHERE r.net_profit > m.median_net_profit AND r.gross_profit_margin < a.avg_gross_margin ORDER BY r.net_profit DESC",
