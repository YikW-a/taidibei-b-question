  "meta": {
    "source_sql": "WITH industry_avg AS (\n    SELECT \n        AVG(gross_profit_margin) AS avg_gross_profit_margin,\n        AVG(net_profit_margin) AS avg_net_profit_margin\n    FROM financials_view \n    WHERE report_period = '2025Q3' \n      AND stock_abbr IN ('云南白药', '片仔癀', '同仁堂', '白云山', '华润三九', '东阿阿胶', '天士力', '以岭药业', '步长制药', '康恩贝', '九芝堂', '太极集团', '中新药业', '广誉远', '健民集团', '马应龙', '仁和药业', '江中药业', '千金药业', '桂林三金', '沃华医药', '贵州百灵', '振东制药', '益盛药业', '康缘药业', '奇正藏药', '西藏药业', '羚锐制药', '太安堂', '嘉应制药', '紫鑫药业', '佛慈制药', '陇神戎发', '盘龙药业', '寿仙谷', '一品红', '新天药业', '特一药业', '大理药业', '龙津药业', '方盛制药', '贵州三力', '万邦德', '吉贝尔', '葫芦娃', '维康药业', '共同药业', '苑东生物', '泽璟制药', '百奥泰', '前沿生物', '艾力斯', '神州细胞', '君实生物', '康希诺', '康泰生物', '智飞生物', '沃森生物', '华兰生物', '天坛生物', '博雅生物', '卫光生物', '双林生物')\n)\nSELECT \n    f.stock_code,\n    f.stock_abbr,\n    f.gross_profit_margin,\n    f.net_profit_margin,\n    i.avg_gross_profit_margin,\n    i.avg_net_profit_margin\nFROM financials_view f\nCROSS JOIN industry_avg i\nWHERE f.report_period = '2025Q3' \n  AND f.stock_abbr IN ('云南白药', '片仔癀', '同仁堂', '白云山', '华润三九', '东阿阿胶', '天士力', '以岭药业', '步长制药', '康恩贝', '九芝堂', '太极集团', '中新药业', '广誉远', '健民集团', '马应龙', '仁和药业', '江中药业', '千金药业', '桂林三金', '沃华医药', '贵州百灵', '振东制药', '益盛药业', '康缘药业', '奇正藏药', '西藏药业', '羚锐制药', '太安堂', '嘉应制药', '紫鑫药业', '佛慈制药', '陇神戎发', '盘龙药业', '寿仙谷', '一品红', '新天药业', '特一药业', '大理药业', '龙津药业', '方盛制药', '贵州三力', '万邦德', '吉贝尔', '葫芦娃', '维康药业', '共同药业', '苑东生物', '泽璟制药', '百奥泰', '前沿生物', '艾力斯', '神州细胞', '君实生物', '康希诺', '康泰生物', '智飞生物', '沃森生物', '华兰生物', '天坛生物', '博雅生物', '卫光生物', '双林生物')\n  AND f.gross_profit_margin > i.avg_gross_profit_margin\n  AND f.net_profit_margin > i.avg_net_profit_margin\nORDER BY f.stock_code;",
