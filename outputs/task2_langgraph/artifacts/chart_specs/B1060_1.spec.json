  "meta": {
    "source_sql": "WITH ranked AS (\n  SELECT\n    stock_code,\n    stock_abbr,\n    rnd_expense_ratio,\n    net_profit_yoy_growth,\n    ROW_NUMBER() OVER (ORDER BY rnd_expense_ratio DESC) AS rank_desc,\n    ROW_NUMBER() OVER (ORDER BY rnd_expense_ratio ASC) AS rank_asc\n  FROM financials_view\n  WHERE report_period = '2025Q3'\n    AND rnd_expense_ratio IS NOT NULL\n    AND net_profit_yoy_growth IS NOT NULL\n)\nSELECT\n  CASE\n    WHEN rank_desc <= 10 THEN 'Top10_RD'\n    WHEN rank_asc <= 10 THEN 'Bottom10_RD'\n  END AS group_label,\n  stock_code,\n  stock_abbr,\n  rnd_expense_ratio,\n  net_profit_yoy_growth\nFROM ranked\nWHERE rank_desc <= 10 OR rank_asc <= 10\nORDER BY group_label, rnd_expense_ratio DESC",
