  "meta": {
    "source_sql": "WITH base AS (\n    SELECT\n        stock_code,\n        stock_abbr,\n        MAX(CASE WHEN report_period = '2022FY' THEN total_operating_revenue END) AS revenue_2022,\n        MAX(CASE WHEN report_period = '2025Q3' THEN total_operating_revenue END) AS revenue_2025q3\n    FROM financials_view\n    WHERE report_period IN ('2022FY', '2025Q3')\n    GROUP BY stock_code, stock_abbr\n    HAVING revenue_2022 IS NOT NULL AND revenue_2022 > 0 AND revenue_2025q3 IS NOT NULL\n)\nSELECT\n    stock_code,\n    stock_abbr,\n    ROUND(POWER(revenue_2025q3 / revenue_2022, 1.0 / 3.0) - 1, 4) * 100 AS compound_growth_rate_percent\nFROM base\nORDER BY compound_growth_rate_percent DESC\nLIMIT 3",
    "value_fields": [
      "compound_growth_rate_percent"
    ],
