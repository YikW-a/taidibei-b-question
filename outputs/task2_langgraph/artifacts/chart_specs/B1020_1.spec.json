  "meta": {
    "source_sql": "WITH top_unappropriated AS (\n    SELECT stock_code, stock_abbr, equity_unappropriated_profit AS unappropriated_profit\n    FROM financials_view\n    WHERE report_period = '2025Q3'\n    ORDER BY equity_unappropriated_profit DESC\n    LIMIT 5\n)\nSELECT \n    t.stock_code,\n    t.stock_abbr,\n    t.unappropriated_profit,\n    fv.net_profit AS net_profit_2025,\n    CASE \n        WHEN t.unappropriated_profit != 0 THEN (fv.net_profit / t.unappropriated_profit) * 100\n        ELSE NULL\n    END AS net_profit_to_unappropriated_ratio_percent\nFROM top_unappropriated t\nLEFT JOIN financials_view fv ON t.stock_code = fv.stock_code AND fv.report_period = '2025FY'\nORDER BY t.unappropriated_profit DESC;",
