  "meta": {
    "source_sql": "WITH base AS (\n    SELECT\n        stock_abbr,\n        operating_expense_rnd_expenses AS rnd_expense,\n        total_operating_revenue AS operating_revenue\n    FROM financials_view\n    WHERE report_period = '2025Q3'\n        AND operating_expense_rnd_expenses IS NOT NULL\n        AND total_operating_revenue IS NOT NULL\n        AND total_operating_revenue != 0\n)\nSELECT\n    stock_abbr,\n    (rnd_expense / operating_revenue) * 100 AS rnd_expense_ratio_percent\nFROM base\nORDER BY rnd_expense_ratio_percent DESC\nLIMIT 5",
