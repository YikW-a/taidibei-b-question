  "meta": {
    "source_sql": "WITH cost_ratio AS (\n  SELECT stock_code, stock_abbr, report_period, operating_expense_cost_of_sales, total_operating_revenue,\n         CASE WHEN total_operating_revenue > 0 THEN operating_expense_cost_of_sales / total_operating_revenue ELSE NULL END AS cost_revenue_ratio\n  FROM financials_view\n  WHERE report_period = '2025Q3'\n    AND total_operating_revenue IS NOT NULL\n    AND operating_expense_cost_of_sales IS NOT NULL\n)\nSELECT stock_code, stock_abbr, cost_revenue_ratio\nFROM cost_ratio\nWHERE cost_revenue_ratio IS NOT NULL\nORDER BY cost_revenue_ratio DESC\nLIMIT 10",
