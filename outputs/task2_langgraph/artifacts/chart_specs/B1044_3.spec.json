  "meta": {
    "source_sql": "WITH company_data AS (\n    SELECT \n        stock_code,\n        stock_abbr,\n        net_profit,\n        net_profit_yoy_growth\n    FROM financials_view\n    WHERE report_period = '2025Q3'\n        AND stock_abbr IN ('白云山', '云南白药', '华润三九', '同仁堂', '太极集团')\n),\nindustry_avg AS (\n    SELECT \n        AVG(net_profit_yoy_growth) AS avg_net_profit_yoy_growth\n    FROM financials_view\n    WHERE report_period = '2025Q3'\n        AND stock_abbr IN ('白云山', '云南白药', '华润三九', '同仁堂', '太极集团')\n)\nSELECT \n    c.stock_code,\n    c.stock_abbr,\n    c.net_profit,\n    c.net_profit_yoy_growth,\n    i.avg_net_profit_yoy_growth\nFROM company_data c\nCROSS JOIN industry_avg i\nORDER BY c.net_profit DESC\nLIMIT 5",
