  "meta": {
    "source_sql": "WITH ranked AS (\n  SELECT\n    stock_abbr,\n    asset_inventory AS 存货_万元,\n    total_operating_revenue AS 营业总收入_万元,\n    total_operating_revenue / NULLIF(asset_inventory, 0) AS 比值,\n    ROW_NUMBER() OVER (ORDER BY asset_inventory DESC) AS rn\n  FROM financials_view\n  WHERE report_period = '2025Q3'\n    AND asset_inventory IS NOT NULL\n    AND total_operating_revenue IS NOT NULL\n)\nSELECT\n  stock_abbr AS 公司简称,\n  存货_万元,\n  营业总收入_万元,\n  比值\nFROM ranked\nWHERE rn <= 3\nORDER BY rn;",
