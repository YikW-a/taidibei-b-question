  "meta": {
    "source_sql": "WITH ranked_2024 AS (\n    SELECT stock_code, stock_abbr, report_period, net_profit_yoy_growth AS net_profit_yoy_growth_rate,\n           ROW_NUMBER() OVER (ORDER BY net_profit_yoy_growth DESC) AS rank\n    FROM financials_view\n    WHERE report_period = '2024Q3'\n      AND net_profit_yoy_growth IS NOT NULL\n), ranked_2025 AS (\n    SELECT stock_code, stock_abbr, report_period, net_profit_yoy_growth AS net_profit_yoy_growth_rate,\n           ROW_NUMBER() OVER (ORDER BY net_profit_yoy_growth DESC) AS rank\n    FROM financials_view\n    WHERE report_period = '2025Q3'\n      AND net_profit_yoy_growth IS NOT NULL\n)\nSELECT '2024Q3' AS report_period, stock_code, stock_abbr, net_profit_yoy_growth_rate, rank\nFROM ranked_2024\nWHERE rank <= 10\nUNION ALL\nSELECT '2025Q3' AS report_period, stock_code, stock_abbr, net_profit_yoy_growth_rate, rank\nFROM ranked_2025\nWHERE rank <= 10\nORDER BY report_period, rank",
