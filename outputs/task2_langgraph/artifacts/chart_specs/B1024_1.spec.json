  "meta": {
    "source_sql": "WITH diff_cte AS (\n    SELECT\n        stock_abbr,\n        net_profit AS 净利润,\n        net_profit_excl_non_recurring AS 扣非净利润,\n        ABS(net_profit - net_profit_excl_non_recurring) AS 差值\n    FROM financials_view\n    WHERE report_period = '2025Q3'\n        AND net_profit IS NOT NULL\n        AND net_profit_excl_non_recurring IS NOT NULL\n)\nSELECT\n    stock_abbr AS 简称,\n    净利润,\n    扣非净利润,\n    差值\nFROM diff_cte\nORDER BY 差值 DESC\nLIMIT 5",
