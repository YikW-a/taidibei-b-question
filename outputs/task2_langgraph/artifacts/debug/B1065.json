    "meta": {
      "source_sql": "WITH filtered_companies AS (\n    SELECT stock_code, stock_abbr, operating_revenue_yoy_growth\n    FROM financials_view\n    WHERE report_period = '2025Q3'\n      AND stock_abbr IN ('白云山', '云南白药', '片仔癀', '同仁堂', '东阿阿胶', '华润三九', '太极集团', '天士力', '以岭药业', '步长制药', '康恩贝', '九芝堂', '中新药业', '广誉远', '健民集团', '马应龙', '仁和药业', '江中药业', '千金药业', '桂林三金', '沃华医药', '贵州百灵', '振东制药', '益盛药业', '香雪制药', '康缘药业', '红日药业', '华海药业', '众生药业', '上海凯宝', '福瑞股份', '莱美药业', '康弘药业', '西藏药业', '中恒集团', '吉林敖东', '羚锐制药', '康美药业', '紫鑫药业', '通化金马', '通化东宝', '长春高新', '双鹭药业', '海思科', '誉衡药业', '华仁药业', '仟源医药', '博腾股份', '山河药辅', '尔康制药', '诚意药业', '卫信康', '华森制药', '盘龙药业', '特一药业', '新天药业', '贵州三力', '葫芦娃', '维康药业', '万邦德', '陇神戎发', '奇正藏药', '嘉应制药', '太安堂', '益佰制药')\n)\nSELECT \n    fc.stock_code,\n    fc.stock_abbr,\n    fc.operating_revenue_yoy_growth,\n    fv.report_period,\n    fv.total_operating_revenue\nFROM filtered_companies fc\nJOIN financials_view fv ON fc.stock_code = fv.stock_code\nWHERE fv.report_period IN ('2023Q3', '2024Q3', '2025Q3')\nORDER BY fc.stock_code, fv.report_period;",
