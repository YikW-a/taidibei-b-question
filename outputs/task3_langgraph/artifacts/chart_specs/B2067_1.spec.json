  "meta": {
    "source_sql": "WITH dongeejiao_data AS (\n    SELECT \n        report_period,\n        report_year,\n        total_operating_revenue\n    FROM financials_view \n    WHERE stock_abbr = '东阿阿胶' \n        AND report_period IN ('2022Q3', '2023Q3', '2024Q3', '2025Q3')\n    ORDER BY report_period\n)\nSELECT \n    report_period,\n    report_year,\n    total_operating_revenue,\n    LAG(total_operating_revenue, 1) OVER (ORDER BY report_period) AS prev_q3_revenue,\n    CASE \n        WHEN LAG(total_operating_revenue, 1) OVER (ORDER BY report_period) IS NOT NULL \n        THEN ROUND((total_operating_revenue * 1.0 / LAG(total_operating_revenue, 1) OVER (ORDER BY report_period) - 1) * 100, 2)\n        ELSE NULL \n    END AS yoy_growth_percent\nFROM dongeejiao_data;",
    "value_fields": [
      "total_operating_revenue"
    ],
    "value_labels": [
      "营业总收入"
    ],
    "original_chart_plan": {
