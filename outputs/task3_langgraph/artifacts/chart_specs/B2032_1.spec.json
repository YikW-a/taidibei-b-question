  "meta": {
    "source_sql": "WITH financials_2025q3 AS (\n    SELECT \n        stock_code,\n        stock_abbr,\n        report_period,\n        selling_expenses,\n        total_operating_revenue\n    FROM financials_view\n    WHERE report_period = '2025Q3'\n        AND selling_expenses IS NOT NULL\n        AND total_operating_revenue IS NOT NULL\n        AND total_operating_revenue > 0\n)\nSELECT \n    stock_code,\n    stock_abbr,\n    report_period,\n    selling_expenses,\n    total_operating_revenue,\n    ROUND((selling_expenses * 1.0 / total_operating_revenue) * 100, 2) AS selling_expense_ratio_percent\nFROM financials_2025q3\nORDER BY selling_expense_ratio_percent DESC\nLIMIT 5;",
