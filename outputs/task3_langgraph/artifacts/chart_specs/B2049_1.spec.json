  "meta": {
    "source_sql": "WITH industry_avg AS (\n    SELECT \n        AVG(selling_expenses * 1.0 / NULLIF(total_operating_revenue, 0)) * 100 AS avg_selling_expense_ratio\n    FROM financials_view \n    WHERE report_period = '2025Q3'\n        AND total_operating_revenue > 0\n),\ncompany_ratios AS (\n    SELECT \n        stock_code,\n        stock_abbr,\n        total_operating_revenue,\n        net_profit,\n        selling_expenses,\n        CASE \n            WHEN total_operating_revenue > 0 \n            THEN selling_expenses * 1.0 / total_operating_revenue * 100 \n            ELSE NULL \n        END AS selling_expense_ratio\n    FROM financials_view \n    WHERE report_period = '2025Q3'\n        AND total_operating_revenue > 0\n)\nSELECT \n    cr.stock_code,\n    cr.stock_abbr,\n    cr.selling_expense_ratio,\n    ia.avg_selling_expense_ratio,\n    cr.total_operating_revenue,\n    cr.net_profit,\n    cr.selling_expenses,\n    CASE \n        WHEN cr.net_profit > 0 AND cr.total_operating_revenue > 0 \n        THEN cr.net_profit * 1.0 / cr.total_operating_revenue * 100 \n        ELSE NULL \n    END AS net_profit_margin\nFROM company_ratios cr\nCROSS JOIN industry_avg ia\nWHERE cr.selling_expense_ratio < ia.avg_selling_expense_ratio\nORDER BY cr.selling_expense_ratio ASC;",
    "value_fields": [
      "stock_code",
      "selling_expense_ratio",
      "avg_selling_expense_ratio",
      "total_operating_revenue"
    ],
