  "meta": {
    "source_sql": "SELECT \n    report_period,\n    total_profit AS 利润总额\nFROM financials_view \nWHERE stock_abbr = '片仔癀' \n    AND report_period IN ('2021FY', '2022FY', '2023FY', '2024FY', '2025H1') \nORDER BY \n    CASE \n        WHEN report_period LIKE '%FY' THEN CAST(SUBSTR(report_period, 1, 4) AS INTEGER) \n        WHEN report_period LIKE '%H1' THEN CAST(SUBSTR(report_period, 1, 4) AS INTEGER) \n        ELSE 0 \n    END,\n    CASE \n        WHEN report_period LIKE '%H1' THEN 1 \n        WHEN report_period LIKE '%FY' THEN 2 \n        ELSE 3 \n    END;",
