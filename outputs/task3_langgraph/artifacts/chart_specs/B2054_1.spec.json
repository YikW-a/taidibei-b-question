  "meta": {
    "source_sql": "WITH cash_ratio AS (\n    SELECT \n        stock_code,\n        stock_abbr,\n        asset_cash_and_cash_equivalents AS 货币资金,\n        total_assets AS 总资产,\n        ROUND(CAST(asset_cash_and_cash_equivalents AS REAL) / NULLIF(total_assets, 0) * 100, 2) AS 货币资金占总资产比例,\n        investing_cf_net_amount AS 投资性现金流量净额\n    FROM financials_view\n    WHERE report_period = '2025Q3'\n        AND total_assets IS NOT NULL\n        AND asset_cash_and_cash_equivalents IS NOT NULL\n        AND investing_cf_net_amount IS NOT NULL\n)\nSELECT \n    stock_code,\n    stock_abbr,\n    货币资金,\n    总资产,\n    货币资金占总资产比例,\n    投资性现金流量净额\nFROM cash_ratio\nORDER BY 货币资金占总资产比例 DESC\nLIMIT 5;",
