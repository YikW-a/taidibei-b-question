  "meta": {
    "source_sql": "WITH top_cf_companies AS (\n    SELECT \n        stock_code,\n        stock_abbr,\n        operating_cf_net_amount AS 经营性现金流量净额,\n        net_profit AS 净利润\n    FROM financials_view\n    WHERE report_period = '2025Q3'\n    ORDER BY operating_cf_net_amount DESC\n    LIMIT 10\n)\nSELECT \n    stock_code,\n    stock_abbr,\n    经营性现金流量净额,\n    净利润,\n    CASE \n        WHEN 净利润 = 0 THEN NULL \n        ELSE ROUND(经营性现金流量净额 * 1.0 / 净利润, 2) \n    END AS 现金流净利润比,\n    CASE \n        WHEN 净利润 = 0 THEN '净利润为零无法计算'\n        WHEN 经营性现金流量净额 * 1.0 / 净利润 > 1 THEN '现金流质量优'\n        ELSE '现金流质量需关注'\n    END AS 现金流质量评价\nFROM top_cf_companies\nORDER BY 经营性现金流量净额 DESC;",
    "value_fields": [
      "经营性现金流量净额"
    ],
