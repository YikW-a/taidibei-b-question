  "meta": {
    "source_sql": "WITH top5_inventory AS (\n    SELECT \n        stock_code,\n        stock_abbr,\n        asset_inventory AS inventory_amount,\n        inventory_turnover_ratio\n    FROM financials_view \n    WHERE report_period = '2025Q3'\n      AND asset_inventory IS NOT NULL\n    ORDER BY asset_inventory DESC\n    LIMIT 5\n),\nindustry_avg AS (\n    SELECT \n        AVG(inventory_turnover_ratio) AS avg_inventory_turnover\n    FROM financials_view \n    WHERE report_period = '2025Q3'\n      AND inventory_turnover_ratio IS NOT NULL\n)\nSELECT \n    t.stock_code,\n    t.stock_abbr,\n    t.inventory_amount,\n    t.inventory_turnover_ratio,\n    i.avg_inventory_turnover,\n    CASE \n        WHEN t.inventory_turnover_ratio < i.avg_inventory_turnover THEN '低于行业均值'\n        ELSE '不低于行业均值'\n    END AS comparison_status\nFROM top5_inventory t\nCROSS JOIN industry_avg i\nWHERE t.inventory_turnover_ratio < i.avg_inventory_turnover\nORDER BY t.inventory_amount DESC;",
    "value_fields": [
      "inventory_amount"
    ],
    "value_labels": [
