  "meta": {
    "source_sql": "WITH ratio_data AS (\n    SELECT \n        stock_code,\n        stock_abbr,\n        equity_unappropriated_profit AS 未分配利润,\n        kpi_net_profit AS 净利润,\n        CASE \n            WHEN kpi_net_profit > 0 THEN equity_unappropriated_profit * 1.0 / kpi_net_profit\n            ELSE NULL \n        END AS 未分配利润净利润比,\n        asset_liability_ratio AS 资产负债率\n    FROM financials_view\n    WHERE report_period = '2025Q3'\n        AND kpi_net_profit IS NOT NULL\n        AND equity_unappropriated_profit IS NOT NULL\n        AND asset_liability_ratio IS NOT NULL\n)\nSELECT \n    stock_code,\n    stock_abbr,\n    未分配利润,\n    净利润,\n    未分配利润净利润比,\n    资产负债率\nFROM ratio_data\nWHERE 未分配利润净利润比 > 5\nORDER BY 未分配利润净利润比 DESC;",
    "value_fields": [
      "stock_code",
      "未分配利润",
      "净利润",
      "未分配利润净利润比"
    ],
