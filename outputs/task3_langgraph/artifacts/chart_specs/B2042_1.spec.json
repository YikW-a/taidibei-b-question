  "meta": {
    "source_sql": "WITH profitable_companies AS (\n    SELECT \n        stock_code,\n        stock_abbr,\n        kpi_net_profit_yoy_growth,\n        rnd_expense_ratio\n    FROM financials_view \n    WHERE report_period = '2025Q3' \n        AND kpi_net_profit_yoy_growth > 0\n),\navg_rnd_ratio AS (\n    SELECT \n        AVG(rnd_expense_ratio) AS avg_rnd_ratio\n    FROM profitable_companies\n),\nhigh_rnd_companies AS (\n    SELECT \n        pc.stock_code,\n        pc.stock_abbr,\n        pc.kpi_net_profit_yoy_growth,\n        pc.rnd_expense_ratio,\n        ar.avg_rnd_ratio\n    FROM profitable_companies pc\n    CROSS JOIN avg_rnd_ratio ar\n    WHERE pc.rnd_expense_ratio > ar.avg_rnd_ratio\n)\nSELECT \n    stock_code,\n    stock_abbr,\n    kpi_net_profit_yoy_growth AS 净利润同比增长率,\n    rnd_expense_ratio AS 研发费用占比,\n    avg_rnd_ratio AS 平均研发费用占比\nFROM high_rnd_companies\nORDER BY rnd_expense_ratio DESC;",
